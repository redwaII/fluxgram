{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "header", "key": "Sec-Fetch-Dest", "value": "document" }],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "header", "key": "Accept", "value": "^text/html" }],
      "destination": "/index.html"
    }
  ]
}
